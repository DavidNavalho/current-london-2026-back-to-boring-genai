KAFKA_BOOTSTRAP_SERVERS=broker:29094
SCHEMA_REGISTRY_URL=http://schema-registry:8081
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_PRINCIPAL=svc-admin
# Demo-only convention: each service password is "<principal>-secret".
# Override these locally if you change docker-compose.yml.
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
CODEX_PROVIDER_MODE=cli
CONFLUENT_PLATFORM_VERSION=8.2.0
AKHQ_VERSION=0.27.0
CODEX_CLI_VERSION=0.130.0
# Host Codex login directory mounted into the app container.
CODEX_HOME=${HOME}/.codex
APP_PORT=8000
